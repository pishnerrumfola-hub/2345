// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: wrongQuestions
// Document ID: auto-generated
// Fields:
//   - userId: string (required) - The ID of the user who owns this record.
//   - originalText: string (required) - The OCR-recognized text of the original question.
//   - userAnswer: string (optional) - The user's original answer.
//   - correctAnswer: string (optional) - The correct answer to the original question.
//   - knowledgePoint: string (required) - The core knowledge point extracted from the question.
//   - variations: list (required) - Three generated variations of the question.
//   - createdAt: timestamp (required) - When the record was created.
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "pishnerrumfola@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidWrongQuestion(data) {
      return data.keys().hasAll(['userId', 'originalText', 'knowledgePoint', 'variations', 'createdAt']) &&
             data.userId is string &&
             data.originalText is string && data.originalText.size() < 5000 &&
             data.knowledgePoint is string && data.knowledgePoint.size() < 200 &&
             data.variations is list && data.variations.size() == 3 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /wrongQuestions/{questionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidWrongQuestion(request.resource.data) && (isOwner(request.resource.data.userId) || isAdmin());
      allow update: if isAuthenticated() && isValidWrongQuestion(request.resource.data) && (isOwner(resource.data.userId) || isAdmin()) && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
